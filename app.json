{
  "expo": {
    "name": "Foodza",
    "slug": "FOODZA",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Variant7.png",
    "scheme": "foodza",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.schuler.foodza",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "com.schuler.foodza",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Variant7.png",
        "backgroundImage": "./assets/images/Variant7.png",
        "monochromeImage": "./assets/images/Variant7.png"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Variant7.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Variant7.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ec266485-b2ad-4ded-97e6-d76ed2d6e6f1"
      }
    },
    "owner": "ayabaws"
  }
}
